{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Celery",
            "type": "debugpy",
            "module": "celery",
            "args": [
              "-A",
              "core.celery:app",
              "worker",
              "--loglevel=info",
              "--beat",
              "--pool=solo",
              "--concurrency=1",
              "--events"
            ],
            "request": "launch",
        },
        {
            "name": "Python: Django",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/manage.py",
            "args": [
                "runserver",
                "0.0.0.0:8000",
                "--settings=core.settings.dev"
            ],
            "django": true,
            "justMyCode": false
        }
    ],
    "compounds": [
        {
            "name": "Celery and Django",
            "configurations": ["Python: Celery", "Python: Django"]
        }
    ]    
}